import spacy

# Load model
nlp = spacy.load("en_core_web_sm")

text = "Emma visited Paris"
doc = nlp(text)

for token in doc:
    if token.dep_ == "nsubj":
        subject = token.text
        verb = token.head.text

        for child in token.head.children:
            if child.dep_ == "dobj":
                obj = child.text
                print("SVO:", subject, verb, obj)

# =======================
print("\nEntities:")
for ent in doc.ents:
    print(ent.text, "->", ent.label_)
